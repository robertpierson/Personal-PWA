# ─────────────────────────────────────────────────────────────────────────────
# Marquee — environment configuration
#
# Copy to `.env.local` for local dev, or set these in your Vercel project.
# NOTHING here is required to run the app: with no vars set, the whole app runs
# in DEMO MODE on bundled data (src/lib/demo/data.ts). Add a group of vars to
# switch that integration live — see src/lib/config.ts for the exact flags.
# ─────────────────────────────────────────────────────────────────────────────

# Public site URL (used for absolute links, OAuth redirects, sitemap/robots).
# In production set this to your deployed origin, e.g. https://marquee.example.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase (Phase 2+) ──────────────────────────────────────────────────────
# Presence of URL + ANON key flips the app OUT of demo mode onto the real DB.
# Find these in Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key: server-only, bypasses RLS. Powers operator writes (admin
# panel, seeding). NEVER expose to the client or commit a real value.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated emails allowed into the /admin operator panel.
OPERATOR_EMAILS=

# ── Token encryption (required once you store third-party OAuth tokens) ───────
# 32-byte secret used to encrypt stored Meta/PayPal tokens at rest.
# Generate one with:  openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# ── PayPal billing (Phase 4) ─────────────────────────────────────────────────
# PAYPAL_ENV: "sandbox" (default) or "live".
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# ── Meta / Instagram Graph API (Phase 3, read-only insights) ─────────────────
# Create an app at developers.facebook.com. Scopes are read-only by design.
META_APP_ID=
META_APP_SECRET=
